HOST=0.0.0.0
PORT=8787
HEARTBEAT_TIMEOUT_SECONDS=60
TICKET_TTL_SECONDS=120
WS_PATH=/control
RELAY_BIND_HOST=0.0.0.0
RELAY_PUBLIC_HOST=CHANGE_ME_PUBLIC_HOST
RELAY_PORT_START=39000
RELAY_PORT_END=39149
RELAY_HOST_IDLE_SECONDS=90
RELAY_CLIENT_IDLE_SECONDS=180
STRICT_GAME_VERSION_CHECK=false
STRICT_MOD_VERSION_CHECK=false
# Seeds the admin-panel MOD-sync toggle on a fresh install. The panel is the runtime source of truth.
MOD_SYNC_ENABLED=true
MOD_SYNC_MAX_DESCRIPTORS=64
MOD_SYNC_MAX_PAYLOAD_BYTES=65536
CONNECTION_STRATEGY=relay-only
SERVER_ADMIN_USERNAME=admin
# Generate with: npm run hash-admin-password -- 'your-password'
SERVER_ADMIN_PASSWORD_HASH=CHANGE_ME_PASSWORD_HASH
# Generate with: node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
SERVER_ADMIN_SESSION_SECRET=CHANGE_ME_SESSION_SECRET
SERVER_ADMIN_SESSION_TTL_HOURS=168
SERVER_ADMIN_STATE_FILE=/app/data/server-admin.json
SERVER_UPDATE_ENABLED=true
SERVER_UPDATE_DATA_DIR=/app/data/service-update
SERVER_UPDATE_CHECK_INTERVAL_MINUTES=360
SERVER_UPDATE_RELEASES_API_URL=
SERVER_UPDATE_DEPLOYMENT_MODE=docker
# --- Decentralized peer network (v0.4.0+) ---
# Set PEER_NETWORK_ENABLED=false to opt out entirely. Any other value keeps
# the peer network on; if PEER_SELF_ADDRESS is also empty, /server-admin
# will show "Peer network unconfigured".
PEER_NETWORK_ENABLED=true
# This lobby's externally-reachable URL. Must be reachable from the public
# internet and from the Cloudflare discovery worker. For HTTPS / reverse-proxy
# deployments, write the proxy's public URL.
PEER_SELF_ADDRESS=http://CHANGE_ME_PUBLIC_HOST:8787
# Cloudflare discovery worker base URL. Used by both the client picker and
# this lobby's bootstrap to aggregate the public node list.
PEER_CF_DISCOVERY_BASE_URL=https://sts2-gamelobby-register.xyz
# Seeds the publicListingEnabled flag on a fresh install. The admin-panel
# toggle is the runtime source of truth.
PEER_PUBLIC_LISTING_ENABLED=true
# Local peer state directory (peers.json + identity keypair).
PEER_STATE_DIR=/app/data/peer
# Optional: override the public-facing server name shown in the client picker.
# PEER_DISPLAY_NAME=My Community Lobby
