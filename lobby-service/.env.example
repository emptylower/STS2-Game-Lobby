HOST=0.0.0.0
PORT=8787
HEARTBEAT_TIMEOUT_SECONDS=60
TICKET_TTL_SECONDS=120
WS_PATH=/control
RELAY_BIND_HOST=0.0.0.0
RELAY_PUBLIC_HOST=
RELAY_PORT_START=39000
RELAY_PORT_END=39149
RELAY_HOST_IDLE_SECONDS=90
RELAY_CLIENT_IDLE_SECONDS=180
STRICT_GAME_VERSION_CHECK=false
STRICT_MOD_VERSION_CHECK=false
CONNECTION_STRATEGY=relay-only
PUBLIC_ROOM_LIST_ENABLED=false
PUBLIC_DETAILED_HEALTH_ENABLED=false
# Whether to enforce lobby read token checks for private room lists / detailed health.
# Default true. Set to false to keep old mods compatible when they cannot send read tokens.
ENFORCE_LOBBY_ACCESS_TOKEN=true
# Whether to enforce create-room token checks.
# Default true. Set to false to keep old mods compatible when they cannot send create-room tokens.
ENFORCE_CREATE_ROOM_TOKEN=true
# Set a strong random token if clients or your trusted proxy need to access private room lists, detailed health, or create rooms over the public network.
# Prefer sending it via x-lobby-access-token / x-create-room-token headers; avoid query-string tokens.
CREATE_ROOM_TOKEN=Jsp-vspQBS8jI1L0aFshxr-wHZo2dyhSsYGvgh-QI8E
# Comma-separated trusted source IPs/CIDRs for direct connections that may bypass CREATE_ROOM_TOKEN.
# Supports IPv4, IPv6, and IPv4-mapped IPv6 peer addresses.
# Note: this only applies to the actual TCP peer address; x-forwarded-for is not trusted here.
# Example: 127.0.0.1,::1,10.0.0.0/8,192.168.0.0/16
CREATE_ROOM_TRUSTED_PROXIES=127.0.0.1,::1
# Lightweight per-IP rate limit for create/join requests.
CREATE_JOIN_RATE_LIMIT_WINDOW_MS=60000
CREATE_JOIN_RATE_LIMIT_MAX_REQUESTS=30
# --- Phase 1 server chat ---
SERVER_CHAT_ENABLED=false
SERVER_CHAT_HISTORY_LIMIT=100
SERVER_CHAT_HISTORY_TTL_HOURS=24
SERVER_CHAT_SNAPSHOT_LIMIT=50
SERVER_CHAT_MAX_PAYLOAD_BYTES=8192
SERVER_CHAT_MAX_CONNECTIONS_PER_IP=10
SERVER_CHAT_MAX_CONNECTIONS_TOTAL=500
SERVER_CHAT_MAX_PENDING_TICKETS=2000
SERVER_CHAT_TRUSTED_PROXY_CIDRS=
SERVER_ADMIN_USERNAME=admin
# Generate with: npm run hash-admin-password -- 'your-password'
SERVER_ADMIN_PASSWORD_HASH=
# Generate with: node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
SERVER_ADMIN_SESSION_SECRET=
SERVER_ADMIN_SESSION_TTL_HOURS=168
SERVER_ADMIN_STATE_FILE=./data/server-admin.json
# --- Decentralized peer network (v0.4.0+) ---
# Set PEER_NETWORK_ENABLED=false to opt out entirely. Any other value (or
# leaving it unset) keeps the peer network on; if PEER_SELF_ADDRESS is also
# empty, /server-admin will show "Peer network unconfigured".
PEER_NETWORK_ENABLED=true
# This lobby's externally-reachable URL. Must be reachable from the public
# internet and from the Cloudflare discovery worker — leaving this empty
# while PEER_NETWORK_ENABLED=true is the most common fresh-install mistake.
# For HTTPS / reverse-proxy deployments, write the proxy's public URL.
PEER_SELF_ADDRESS=
# Cloudflare discovery worker base URL. Used by both the client picker and
# this lobby's bootstrap to aggregate the public node list. Leave empty to
# run fully detached from CF discovery (private-direct deployments).
PEER_CF_DISCOVERY_BASE_URL=https://sts2-gamelobby-register.xyz
# Seeds the publicListingEnabled flag on a fresh install. The admin-panel
# toggle is the runtime source of truth; flipping it persists into
# SERVER_ADMIN_STATE_FILE. Set false to keep this node visible only to
# players who already know its address.
PEER_PUBLIC_LISTING_ENABLED=true
# Local peer state directory (peers.json + identity keypair).
PEER_STATE_DIR=./data/peer
# Optional: override the public-facing server name shown in the client
# picker. Falls back to the admin-panel-managed display name, then to a
# host-derived label.
# PEER_DISPLAY_NAME=My Community Lobby
