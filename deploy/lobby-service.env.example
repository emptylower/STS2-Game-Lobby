HOST=0.0.0.0
PORT=8787
HEARTBEAT_TIMEOUT_SECONDS=60
TICKET_TTL_SECONDS=120
WS_PATH=/control
RELAY_BIND_HOST=0.0.0.0
RELAY_PUBLIC_HOST=CHANGE_ME_PUBLIC_HOST
RELAY_PORT_START=39000
RELAY_PORT_END=39149
RELAY_HOST_IDLE_SECONDS=90
RELAY_CLIENT_IDLE_SECONDS=180
STRICT_GAME_VERSION_CHECK=false
STRICT_MOD_VERSION_CHECK=false
CONNECTION_STRATEGY=relay-only
SERVER_ADMIN_USERNAME=admin
SERVER_ADMIN_PASSWORD_HASH=CHANGE_ME_PASSWORD_HASH
SERVER_ADMIN_SESSION_SECRET=CHANGE_ME_SESSION_SECRET
SERVER_ADMIN_SESSION_TTL_HOURS=168
SERVER_ADMIN_STATE_FILE=/app/data/server-admin.json
# v0.4.0+: opt-in to the decentralized public node list. true → this lobby
# advertises itself via /peers/announce and is aggregated by the CF discovery
# worker. false → this lobby still serves players who know its address but
# is not listed publicly. Admin panel toggle overrides at runtime; this env
# only seeds the value on a fresh install.
PEER_PUBLIC_LISTING_ENABLED=true
# CF discovery worker base URL — clients and lobby seed bootstrap both read
# from this for the public node list. Leave empty to run the lobby in
# fully-private mode without any CF coupling.
PEER_CF_DISCOVERY_BASE_URL=https://sts2-gamelobby-register.xyz
# This lobby's own externally-reachable URL — required for the peer
# network to advertise it. Must be reachable from CF and from clients.
PEER_SELF_ADDRESS=http://CHANGE_ME_PUBLIC_HOST:8787
# Optional display name shown in the client picker. Falls back to the
# admin-panel name, then to "社区服务器 <host>".
# PEER_DISPLAY_NAME=My Community Lobby
# Local peer state directory (peers.json + identity keypair).
PEER_STATE_DIR=/app/data/peer
